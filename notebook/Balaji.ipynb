   "source": [
    "calculated_total = orders['item_price'] * orders['quantity']\n",
    "diff_amount = orders['transaction_amount'] - calculated_total\n",
    "hiden_costs = np.abs(diff_amount).sum() # - сумма разностей по модулю\n",
    "print(f\"Сумма всех комиссий, налогов и скидок (по модулю): {hiden_costs}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "6cc360af-4d07-4d6a-90c6-d327e3d69fce",
